@using BPSeznamUkolu.Configuration
@page "/"

<div class="container mt-4">
    <h2 class="mb-4">Checklist</h2>

    <EditForm Model="@_newItem" OnValidSubmit="OnAddChecklistItem">
        <DataAnnotationsValidator />

        <div class="input-group mb-4 shadow-sm">
            <div class="form-floating flex-grow-1">
                <InputText id="nameInput" class="form-control" placeholder="Název" @bind-Value="_newItem.Name" />
                <label for="nameInput">Název položky</label>
            
                <ValidationMessage For="@(() => _newItem.Name)" class="text-danger small" />
            </div>

            <div class="form-floating w-50">
                <InputText id="descInput" class="form-control" placeholder="Popis" @bind-Value="_newItem.Description" />
                <label for="descInput">Popis položky</label>
                <ValidationMessage For="@(() => _newItem.Description)" class="text-danger small" />
            </div>

            <button type="submit" class="btn btn-primary px-4">Přidat</button>
        </div>
    </EditForm>

    @* Tabulka *@
    <div class="table-responsive shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;" class="text-center">Stav</th>
                    <th style="width: 30%;">Název</th>
                    <th>Popis</th>
                    <th style="width: 140px;" class="text-center">Akce</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _checklistItems) {
                    <tr class="
                        @((item.IsChecked && IsItemValid(item)) ? "opacity-75" : "")
                        @(!IsItemValid(item) ? "table-danger" : "")">
                        <td class="text-center">
                            <input type="checkbox"
                                   class="form-check-input fs-5"
                                   disabled="@(!IsItemValid(item))"
                                   @bind="item.IsChecked"
                                   @bind:after="() => OnUpdateChecklistItem(item)" />
                        </td>
                        <td>
                            @* ZDE JE ZMĚNA v atributu title *@
                            <input type="text"
                                   class="form-control border-0 bg-transparent @(IsItemValid(item) ? "" : "is-invalid")"
                                   title="@(!IsItemValid(item) ? GetErrorMessage(item) : "")"
                                   maxlength="@ChecklistSettings.MaxItemNameLength"
                                   @bind="item.Name"
                                   @bind:after="() => OnUpdateChecklistItem(item)" />
                        </td>
                        <td>
                            <input type="text"
                                   class="form-control border-0 bg-transparent"
                                   maxlength="@ChecklistSettings.MaxDescriptionLength"
                                   disabled="@(!IsItemValid(item))"
                                   @bind="item.Description"
                                   @bind:after="() => OnUpdateChecklistItem(item)" />
                        </td>
                        <td class="text-center">
                            <button class="btn btn-outline-danger btn-sm ms-1"
                                    @onclick="() => OnDeleteChecklistItem(item)">
                                ✖
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>